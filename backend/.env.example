# Required — copy to .env and fill in values before running
DATABASE_URL=postgresql+asyncpg://user:password@postgres:5432/intellihall
SECRET_KEY=change-me-to-a-secure-random-string-minimum-32-chars
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_BYTES=5242880
MAX_IMAGES_PER_COMPLAINT=5
MODEL_DIR=app/ai/models

# Optional
LOG_LEVEL=INFO
